# Terra Triage — environment variables
# Copy to .env.local and fill in. Never commit real secrets.

# --- LLM ---
# Gemini 2.0 Flash API key (AI Studio, free tier)
GEMINI_API_KEY=

# --- Backboard (memory / ranking) ---
# Hackathon preview key
BACKBOARD_API_KEY=

# --- Auth0 (for AI Agents) ---
# e.g. terra-triage.us.auth0.com
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Audience for the scoped agent token (referral:send)
AUTH0_AGENT_AUDIENCE=

# --- Supabase ---
# Server-only project URL
SUPABASE_URL=
# Public URL + anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server only, bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE=

# --- Email (Resend) ---
RESEND_API_KEY=
# Fallback: onboarding@resend.dev
RESEND_FROM=

# --- Magic link ---
# HMAC secret for outcome magic-links (random 32+ bytes)
MAGIC_LINK_SECRET=

# --- Admin ---
# Basic auth for /admin — format user:pass
ADMIN_BASIC_AUTH=
