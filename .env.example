# Terra Triage — environment variables
# Copy to .env.local and fill in. Never commit real secrets.

# --- LLM ---
# Gemini 2.0 Flash API key (AI Studio, free tier)
GEMINI_API_KEY=

# --- Backboard (memory / ranking) ---
# Hackathon preview key
BACKBOARD_API_KEY=

# --- Auth0 (for AI Agents) ---
# e.g. terra-triage.us.auth0.com
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Audience for the scoped agent token (referral:send)
AUTH0_AGENT_AUDIENCE=
# 32-byte hex (e.g. `openssl rand -hex 32`) — cookie encryption
AUTH0_SECRET=
# Public base URL of this app (defaults to http://localhost:3000)
AUTH0_BASE_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
# Optional M2M client (fallback when the AI-Agents primitives are unavailable
# on the tenant). If set, the dispatcher will mint a client_credentials token
# with `referral:send` scope scoped to AUTH0_AGENT_AUDIENCE.
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=

# --- Supabase ---
# Server-only project URL
SUPABASE_URL=
# Public URL + anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server only, bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE=

# --- Email (Resend) ---
RESEND_API_KEY=
# Fallback: onboarding@resend.dev
RESEND_FROM=

# --- Email (Gmail SMTP edge fallback) ---
# Triggered only when Resend returns 429/5xx. Requires a Google App Password:
# https://myaccount.google.com/apppasswords  (2FA must be on).
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=

# --- Magic link ---
# HMAC secret for outcome magic-links (random 32+ bytes)
MAGIC_LINK_SECRET=

# --- Admin ---
# Basic auth for /admin — format user:pass (e.g. admin:changeme).
# WARNING: if unset, /admin/* returns 503 by design. Pick a strong password;
# this gates rank_explain, memory snapshots, and finder PII.
ADMIN_BASIC_AUTH=admin:changeme
